---
import '../styles/theme.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  heroImage?: string;
  noindex?: boolean;
  breadcrumbs?: { name: string; url: string }[];
}

const { title, description, canonical, heroImage, noindex, breadcrumbs } = Astro.props;
const canonicalURL = canonical ? `https://www.triangledehumidifiers.com${canonical}` : undefined;
const ogImage = `https://www.triangledehumidifiers.com${heroImage ?? '/images/hero-livingroom.webp'}`;

const breadcrumbSchema = breadcrumbs && breadcrumbs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name,
    item: `https://www.triangledehumidifiers.com${item.url}`,
  })),
} : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {canonicalURL && <link rel="canonical" href={canonicalURL} />}

    <!-- Breadcrumb Schema -->
    {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {canonicalURL && <meta property="og:url" content={canonicalURL} />}
    <meta property="og:site_name" content="Triangle Dehumidifiers, LLC" />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Performance -->
    <link rel="preload" as="image" href="/logo.webp" />
    {heroImage && <link rel="preload" as="image" href={heroImage} fetchpriority="high" />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body
    ><!-- TOP BAR + HEADER: sticky wrapper -->
    <div class="sticky-header">
      <div class="topbar">
        <div class="container topbar-inner">
          <span class="topbar-left">Serving Raleigh, Wake County &amp; the Triangle Region</span>
          <span class="topbar-right"
            ><a
              href="tel:9198670580"
              style="color:inherit;text-decoration:none;"
              aria-label="Call Triangle Dehumidifiers at (919) 867-0580">(919) 867-0580</a
            > &middot; <a
              href="sms:9198670580"
              style="color:inherit;text-decoration:none;"
              aria-label="Text Triangle Dehumidifiers at (919) 867-0580">Text Us</a
            ></span
          >
        </div>
      </div>

      <header class="site-header">
        <div class="container header-inner">
          <a href="/" class="site-logo">
            <img
              src="/logo.webp"
              alt="Triangle Dehumidifiers, LLC"
              class="logo-img"
              width="79"
              height="65"
              fetchpriority="high"
            />
          </a>
          <nav aria-label="Primary Navigation">
            <ul class="site-nav" id="site-nav">
              <li class="nav-home-only"><a href="/">Home</a></li>
              <li><a href="/crawlspace-dehumidifier-installation-raleigh">Vented Crawlspace</a></li>
              <li>
                <a href="/encapsulated-crawlspace-dehumidifier-raleigh-nc"
                  >Encapsulated Crawlspace</a
                >
              </li>
              <li><a href="/whole-house-dehumidifier-raleigh">Whole-Home</a></li>
              <li><a href="/erv-installation-raleigh-nc">Ventilation</a></li>
              <li><a href="/crawlspace-mold-treatment-raleigh">Mold Treatment</a></li>
              <li><a href="/service-areas">Service Areas</a></li>
              <li><a href="/blog">Blog</a></li>
              <li><a href="/contact" class="nav-cta">Get Inspection</a></li>
            </ul>
            <button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu">
              <span class="nav-toggle__bars">
                <span></span><span></span><span></span>
              </span>
              <span class="nav-toggle__label" id="nav-toggle-label">Menu</span>
            </button>
          </nav>
        </div>
      </header>
    </div>
    <!-- PAGE CONTENT -->
    <main>
      <slot />
    </main>

    <!-- FOOTER -->
    <footer class="site-footer">
      <div class="container">
        <div class="footer-nap">
          <p><strong>Triangle Dehumidifiers, LLC</strong></p>
          <p>Holly Springs, NC</p>
          <p>
            <a href="tel:9198670580" style="color:inherit;text-decoration:none;" aria-label="Call Triangle Dehumidifiers at (919) 867-0580"
              >Call (919) 867-0580</a
            > &middot; <a href="sms:9198670580" style="color:inherit;text-decoration:none;" aria-label="Text Triangle Dehumidifiers at (919) 867-0580"
              >Text Us</a
            >
          </p>
          <p>Serving <a href="/crawl-space-dehumidifier-raleigh-nc" style="color:inherit;">Raleigh</a>, <a href="/crawl-space-dehumidifier-holly-springs-nc" style="color:inherit;">Holly Springs</a>, <a href="/crawl-space-dehumidifier-cary-nc" style="color:inherit;">Cary</a>, <a href="/crawl-space-dehumidifier-apex-nc" style="color:inherit;">Apex</a>, <a href="/crawl-space-dehumidifier-fuquay-varina-nc" style="color:inherit;">Fuquay-Varina</a> &amp; the Triangle region</p>
        </div>

        <ul class="footer-links">
          <li><a href="/">Home</a></li>
          <li><a href="/crawlspace-dehumidifier-installation-raleigh">Vented Crawlspace</a></li>
          <li>
            <a href="/encapsulated-crawlspace-dehumidifier-raleigh-nc">Encapsulated Crawlspace</a>
          </li>
          <li><a href="/whole-house-dehumidifier-raleigh">Whole-Home</a></li>
          <li><a href="/erv-installation-raleigh-nc">Ventilation</a></li>
          <li><a href="/crawlspace-mold-treatment-raleigh">Mold Treatment</a></li>
          <li><a href="/service-areas">Service Areas</a></li>
          <li><a href="/contact">Get Inspection</a></li>
          <li><a href="/privacy">Privacy Policy</a></li>
        </ul>

        <p>&copy; {new Date().getFullYear()} Triangle Dehumidifiers, LLC &mdash; All rights reserved.</p>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('nav-toggle');
      const nav = document.getElementById('site-nav');
      const label = document.getElementById('nav-toggle-label');
      toggle?.addEventListener('click', () => {
        const isOpen = nav?.classList.toggle('open');
        if (label) label.textContent = isOpen ? 'Close' : 'Menu';
      });
    </script>
  </body>
</html>
