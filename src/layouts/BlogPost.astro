---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  author: string;
  tags?: string[];
  image?: string;
  imageAlt?: string;
}

const { title, description, date, author, tags, image, imageAlt } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  datePublished: date,
  ...(image ? { image: `https://www.triangledehumidifiers.com${image}` } : {}),
  author: {
    '@type': 'Organization',
    name: 'Triangle Dehumidifiers, LLC',
    url: 'https://www.triangledehumidifiers.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Triangle Dehumidifiers, LLC',
    url: 'https://www.triangledehumidifiers.com',
  },
};
---

<BaseLayout
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Blog', url: '/blog' }, { name: title, url: `/blog/${Astro.params.slug}` }]}
  title={`${title} | Triangle Dehumidifiers Blog`}
  description={description}
  canonical={`/blog/${Astro.params.slug}`}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <!-- HERO -->
  <section class="hero-simple hero-simple--blog">
    <div class="container hero-simple__inner">
      <div class="hero-simple__content">
        <a href="/blog" class="blog-back-link">&larr; Back to Blog</a>
        <h1>{title}</h1>
        <div class="blog-meta">
          <time datetime={date}>{formattedDate}</time>
          <span class="blog-meta-sep">•</span>
          <span>{author}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ARTICLE -->
  <section class="section">
    <div class="container blog-article">
      <div class="blog-content">
        <slot />
      </div>

      <!-- SIDEBAR CTA -->
      <aside class="blog-sidebar">
        <div class="blog-cta-box">
          <h3>Need Humidity Help?</h3>
          <p>We inspect crawlspaces and install dehumidifiers across the Triangle region.</p>
          <a href="/contact" class="btn btn-green">Request Inspection</a>
          <a href="tel:9198670580" class="btn-call btn-call--block" aria-label="Call Triangle Dehumidifiers at (919) 867-0580">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.18 2 2 0 0 1 3.59 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 5.89 5.89l.92-.92a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            (919) 867-0580
          </a>
        </div>
        {
          tags && tags.length > 0 && (
            <div class="blog-tags">
              <h4>Topics</h4>
              <div class="blog-tag-list">
                {tags.map((tag) => (
                  <span class="blog-tag">{tag}</span>
                ))}
              </div>
            </div>
          )
        }
      </aside>
    </div>
  </section>
</BaseLayout>
