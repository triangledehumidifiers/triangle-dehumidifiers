---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildBusinessSchema, cityArea } from '../schemas/business';

const schema = buildBusinessSchema({
  areaServed: cityArea('Apex'),
});

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What humidity level should a crawl space maintain in Apex, NC?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Crawl spaces in Apex should be maintained between 45–50% Relative Humidity (RH). During summer months, outdoor humidity in the Triangle regularly exceeds 75%, which drives crawl space RH well above 70% in homes without active humidity control.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do encapsulated crawl spaces still need dehumidifiers in Apex?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Encapsulation prevents outside air and ground moisture from entering the crawl space, but it does not remove moisture already trapped inside the sealed environment. A dehumidifier is required to actively maintain 45–50% RH after encapsulation.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can crawl space humidity affect indoor air quality?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Through the stack effect, up to half of the air circulating on your first floor originates from the crawl space. High humidity below the house means mold spores, musty odors, and excess moisture travel upward into living areas through floor gaps, plumbing penetrations, and duct systems.',
      },
    },
    {
      '@type': 'Question',
      name: 'How long does crawl space dehumidifier installation take in Apex?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Installation timelines vary by project scope. The process includes an on-site evaluation, equipment sizing, unit installation, condensate drain line routing, and humidity verification before completion.',
      },
    },
    {
      '@type': 'Question',
      name: 'What makes Apex homes prone to crawl space moisture?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Apex experienced rapid residential growth from the 1990s through the 2010s, with most homes built on vented crawl space foundations over Wake County red clay soil. The clay retains moisture and drains poorly, while vented foundations allow humid summer air to enter freely. Combined with Apex's proximity to Middle Creek and Beaver Creek watersheds, these conditions create persistent crawl space humidity problems.",
      },
    },
  ],
};
