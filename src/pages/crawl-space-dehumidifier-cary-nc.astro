              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><circle cx="12" cy="12" r="10"></circle><path d="m9 12 2 2 4-4"></path></svg
            ></span
