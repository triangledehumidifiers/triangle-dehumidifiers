---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildBusinessSchema, cityArea } from '../schemas/business';

const schema = buildBusinessSchema({
  areaServed: cityArea('Fuquay-Varina'),
  description:
    'Professional crawl space dehumidifier installation for homes in Fuquay-Varina, NC. Maintains 45–50% RH to prevent mold, wood rot, and musty odors.',
});

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What humidity level should a crawl space maintain in Fuquay-Varina, NC?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Crawl spaces in Fuquay-Varina should stay between 45–50% Relative Humidity (RH). Summer outdoor humidity in Wake County regularly exceeds 75%, driving uncontrolled crawl spaces well above 70% RH — the threshold where mold growth and wood damage accelerate.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do newer homes in Fuquay-Varina still need crawl space dehumidifiers?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Yes. Newer homes are built tighter with better insulation and sealing, which traps moisture indoors. Modern HVAC systems control temperature but often don't run long enough to adequately remove humidity, especially during mild spring and fall weather. Green lumber and fresh concrete also release moisture for one to two years after construction.",
      },
    },
    {
      '@type': 'Question',
      name: 'Do encapsulated crawl spaces still need dehumidifiers?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Encapsulation blocks outside air and ground moisture from entering, but any humidity sealed inside the space must be actively removed. A dehumidifier maintains 45–50% RH in the encapsulated environment.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can crawl space humidity affect indoor air quality in my Fuquay-Varina home?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Absolutely. Through the stack effect, a large portion of the air on your first floor rises from the crawl space. High humidity below the house means mold spores, musty odors, and excess moisture travel into your living space through floor gaps, plumbing penetrations, and HVAC ductwork.',
      },
    },
    {
      '@type': 'Question',
      name: 'How long does installation take?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Installation timelines vary by project scope. The process covers evaluation, equipment sizing, installation, condensate drain line routing, and humidity verification. Homes needing mold treatment may require additional time.',
      },
    },
  ],
};
