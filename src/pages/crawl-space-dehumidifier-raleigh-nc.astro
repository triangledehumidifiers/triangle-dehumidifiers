---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildBusinessSchema, cityArea } from '../schemas/business';

const schema = buildBusinessSchema({
  areaServed: cityArea('Raleigh'),
});

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What humidity level should a crawl space maintain in Raleigh, NC?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Crawl spaces in Raleigh should be maintained between 45–50% Relative Humidity (RH). Outdoor humidity in the Triangle exceeds 75% for much of the summer, and without active dehumidification, crawl space RH can sustain 70–85% — conditions that promote mold growth and wood deterioration.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do newer Raleigh homes still need crawl space dehumidifiers?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Yes. Newer homes are built with tighter construction — better insulation, house wrap, and sealed windows — which traps moisture indoors with limited natural ventilation. Modern HVAC systems are sized for temperature control, not humidity removal, so they often don't run long enough to pull adequate moisture from indoor air. Green lumber and fresh concrete also release moisture for one to two years after construction. Many homeowners in newer Raleigh neighborhoods see indoor humidity above 60% even with the AC running.",
      },
    },
    {
      '@type': 'Question',
      name: 'Do encapsulated crawl spaces still need dehumidifiers in Raleigh?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Encapsulation seals the crawl space from outside air and ground moisture, but it does not remove humidity already trapped inside the sealed environment. A properly sized dehumidifier is required to maintain 45–50% RH in any encapsulated crawl space.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can crawl space humidity affect indoor air quality in my Raleigh home?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'In older homes, up to 50% of the air circulating on your first floor can rise from the crawl space through a process called the stack effect. High crawl space humidity pushes mold spores, musty odors, and excess moisture upward into living areas through floor penetrations, plumbing chases, and duct systems.',
      },
    },
    {
      '@type': 'Question',
      name: 'How long does crawl space dehumidifier installation take in Raleigh?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Installation timelines vary by project scope. The process includes a crawl space evaluation, equipment sizing, unit installation, condensate drain line routing, and RH verification. Homes with existing mold may require additional surface treatment before or alongside installation.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do crawl space vents work in North Carolina?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'In most Raleigh-area homes, traditional crawl space vents allow humid outdoor air to enter during the summer months. Because outside air often carries more moisture than the crawl space air itself, venting can increase humidity rather than reduce it. A properly designed closed-vent or encapsulated crawl space combined with correctly sized humidity control provides far more consistent results in this climate.',
      },
    },
    {
      '@type': 'Question',
      name: 'Will a dehumidifier eliminate crawl space mold?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A dehumidifier removes the moisture that mold depends on, preventing future growth. However, existing mold typically requires professional surface treatment first. Long-term results come from addressing both: treating active growth and maintaining proper humidity levels afterward.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do I need encapsulation before installing a crawl space dehumidifier?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Not always. We install humidity control in both vented and sealed crawl spaces. Encapsulation improves performance by reducing ground moisture and outside air infiltration, but it is not always a prerequisite. During an inspection, we confirm your crawl space configuration and recommend the most effective path to maintaining 45–50% RH.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I use a retail store-bought dehumidifier in my crawl space?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Typical retail dehumidifiers are not designed for continuous crawl space operation. They often require manual bucket emptying, have insufficient blowers, and may not be rated for the low clearance and high humidity conditions typical of crawl spaces. Professional-grade systems are built for 24/7 operation with automatic drainage.',
      },
    },
  ],
};
