      telephone: '(919) 867-0580',
      url: 'https://www.triangledehumidifiers.com',
      areaServed: { '@type': 'City', name: 'Raleigh', containedInPlace: { '@type': 'State', name: 'North Carolina' } },
      serviceType: 'Crawl Space Dehumidifier Installation',
    },
    {
      '@type': 'Service',
      name: 'Crawl Space Dehumidifier Installation in Raleigh NC',
      provider: { '@type': 'HomeAndConstructionBusiness', name: 'Triangle Dehumidifiers, LLC' },
      areaServed: { '@type': 'City', name: 'Raleigh', containedInPlace: { '@type': 'State', name: 'North Carolina' } },
      description:
        'Professional crawl space dehumidifier installation for homes in Raleigh, NC. Maintains 45–50% RH to prevent mold, wood rot, and musty odors in both older and newer construction.',
    },
  ],
