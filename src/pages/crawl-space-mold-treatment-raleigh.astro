---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildBusinessSchema, ALL_AREAS_SERVED } from '../schemas/business';

const schema = buildBusinessSchema({
  areaServed: ALL_AREAS_SERVED,
});

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What causes mold to grow in crawl spaces in Raleigh, NC?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Crawl Space mold is caused by sustained high Relative Humidity (RH) — typically above 60% for extended periods. In Raleigh and Wake County, the primary drivers are ground moisture evaporating through unprotected soil, humid exterior air entering through open vents, inadequate vapor barrier coverage, and plumbing condensation or leaks. Mold grows on wood framing and subfloor materials when moisture conditions are not controlled.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can crawl space mold spread into living areas?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. The Stack Effect pulls crawl space air upward into the living space through subfloor gaps, plumbing penetrations, and HVAC pathways. Mold spores, musty odors, and elevated humidity from an uncontrolled crawl space can enter and affect the air quality in your home. Correcting crawl space humidity at the source is the most effective way to prevent this.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does bleach kill crawl space mold?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Bleach is not recommended for crawl space mold treatment on wood framing. Bleach does not penetrate porous wood surfaces effectively and can leave behind moisture that promotes regrowth. We use EPA-registered antimicrobial products — including Benefect Botanical Decon 30 and Concrobium Mold Control — which are selected specifically for crawl space wood applications and professional restoration workflows.',
      },
    },
    {
      '@type': 'Question',
      name: 'Will mold come back after crawl space treatment?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Mold will return if the underlying humidity is not corrected. Surface treatment removes existing growth, but if crawl space RH continues to exceed 60%, conditions for regrowth remain. The most effective long-term approach is combining treatment with a dehumidification strategy that maintains crawl space RH at 45–50% year-round.',
      },
    },
    {
      '@type': 'Question',
      name: 'How much does crawl space mold treatment cost in Raleigh, NC?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Crawl Space mold treatment cost varies based on the size of the affected area, accessibility, and whether moisture correction equipment is needed. An in-person inspection is the best way to determine accurate scope and pricing for your specific crawl space.',
      },
    },
  ],
};
---

<BaseLayout
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Crawl Space Mold Removal', url: '/crawl-space-mold-treatment-raleigh' },
  ]}
  title="Crawl Space Mold Treatment Raleigh | Triangle Dehumidifiers"
  description="Crawl space mold treatment in Raleigh, NC. EPA-registered products. Moisture correction first, then surface mold remediation. Serving Wake County."
  canonical="/crawl-space-mold-treatment-raleigh"
  heroImage="/images/mold-crawl-space-raleigh-nc.webp"
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- HERO -->
  <section class="svc-hero">
    <div class="container">
      <h1>Crawl Space Mold Removal &amp; Treatment in Raleigh, NC</h1>
      <span class="svc-hero__direct"
        >Mold is a symptom of a moisture problem. We correct the humidity source first — then
        perform surface mold remediation to remove existing growth and prevent recurrence.</span
      >
      <p class="svc-hero__sub">
        Mold risk increases when crawl space Relative Humidity (RH) stays above ~65% for extended
        periods. We provide professional crawl space mold treatment using EPA-registered
        antimicrobial products selected for crawl space applications.
      </p>
      <div class="svc-hero__actions">
        <a href="/contact/" class="btn btn-green">Schedule Crawl Space Mold Inspection</a>
        <a
          href="tel:9198670580"
          class="btn btn-secondary"
          aria-label="Call Triangle Dehumidifiers at (919) 867-0580">Call (919) 867-0580</a
        >
        <a
          href="sms:9198670580"
          class="btn btn-secondary"
          aria-label="Text Triangle Dehumidifiers at (919) 867-0580">Text (919) 867-0580</a
        >
      </div>
      <p class="hero-trust-line">EPA-registered products. Fully insured.</p>
    </div>
  </section>

  <!-- MOISTURE FIRST -->
  <section class="section">
    <div class="container">
      <div class="svc-split">
        <div>
          <h2>Moisture Correction Comes First</h2>
          <span class="answer-first"
            >Treating mold without correcting the moisture source is temporary — growth will return
            as long as crawl space RH remains above ~65% for extended periods.</span
          >
          <p>
            Most crawl space mold returns because humidity was never corrected. We address both the
            mold and the moisture source — targeting ~50% RH to reduce the conditions that support
            regrowth.
          </p>
          <div class="icon-cards">
            <div class="icon-card">
              <span class="icon-card__icon icon-card__icon--svg">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#7a4a1a"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <!-- Ground line -->
                  <line x1="2" y1="21" x2="22" y2="21" stroke-width="2"></line>
                  <!-- Ground texture dots -->
                  <circle cx="5" cy="22.5" r="0.5" fill="#7a4a1a" stroke="none"></circle>
                  <circle cx="12" cy="22.8" r="0.4" fill="#7a4a1a" stroke="none"></circle>
                  <circle cx="19" cy="22.5" r="0.5" fill="#7a4a1a" stroke="none"></circle>
                  <!-- Wavy vapor arrow 1 -->
                  <path d="M7 19c1.5-2 1.5-4 0-6s-1.5-4 0-6"></path>
                  <polyline points="5.5 9 7 6 8.5 9"></polyline>
                  <!-- Wavy vapor arrow 2 -->
                  <path d="M12 19c1.5-2 1.5-4 0-6s-1.5-4 0-6"></path>
                  <polyline points="10.5 9 12 6 13.5 9"></polyline>
                  <!-- Wavy vapor arrow 3 -->
                  <path d="M17 19c1.5-2 1.5-4 0-6s-1.5-4 0-6"></path>
                  <polyline points="15.5 9 17 6 18.5 9"></polyline>
                </svg>
              </span>
              <div>
                <strong>Ground Moisture</strong>
                <p>Evaporation through unprotected soil raises crawl space RH continuously</p>
              </div>
            </div>
            <div class="icon-card">
              <span class="icon-card__icon icon-card__icon--svg">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path
                    d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2"
                  ></path>
                </svg>
              </span>
              <div>
                <strong>Humid Exterior Air</strong>
                <p>Open crawl space vents allow high-humidity air to enter freely</p>
              </div>
            </div>
            <div class="icon-card">
              <span class="icon-card__icon icon-card__icon--svg">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <!-- pipe with drip -->
                  <rect x="3" y="9" width="18" height="4" rx="2"></rect>
                  <path d="M7 13v2" stroke-linecap="round"></path>
                  <path d="M7 15c0 1.5 1.5 2.5 1.5 4" stroke-linecap="round"></path>
                  <path d="M12 13v3" stroke-linecap="round"></path>
                  <path d="M12 16c0 1.5 1.5 2 1.5 3.5" stroke-linecap="round"></path>
                </svg>
              </span>
              <div>
                <strong>Plumbing &amp; Condensation</strong>
                <p>Leaks or condensation on cold pipes add direct moisture to the space</p>
              </div>
            </div>
            <div class="icon-card">
              <span class="icon-card__icon icon-card__icon--svg">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                  <line x1="4.93" y1="4.93" x2="19.07" y2="19.07"></line>
                </svg>
              </span>
              <div>
                <strong>Missing Vapor Barrier</strong>
                <p>Inadequate vapor barrier coverage dramatically increases moisture load</p>
              </div>
            </div>
          </div>
        </div>
        <div class="svc-split__image" style="padding-top:0;">
          <img
            src="/images/mold-crawl-space-raleigh-nc.webp"
            alt="Mold on crawl space floor joists in Raleigh NC"
            width="780"
            height="320"
            fetchpriority="high"
            style="width:100%;height:320px;object-fit:cover;border-radius:var(--radius-md);display:block;"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- TREATMENT PROCESS -->
  <section class="section">
    <div class="container">
      <div class="svc-split">
        <div>
          <h2>Our Mold Removal &amp; Treatment Process</h2>
          <span class="answer-first"
            >After moisture sources are identified, surface mold on crawl space framing is treated
            with EPA-registered antimicrobial solutions applied directly to affected wood surfaces.</span
          >
          <p>
            We apply treatment by targeted surface cleaning or controlled fogging to reach framing
            areas within the crawl space.
          </p>
          <div class="svc-steps">
            <div class="svc-step">
              <div class="svc-step__num">1</div>
              <div class="svc-step__body">
                <h3>Moisture Source Evaluation</h3>
                <p>
                  Identify and document humidity drivers — ground moisture, air entry points,
                  plumbing, and condensation sources.
                </p>
              </div>
            </div>
            <div class="svc-step">
              <div class="svc-step__num">2</div>
              <div class="svc-step__body">
                <h3>Surface Preparation</h3>
                <p>
                  Prepare affected areas for treatment — targeted surface cleaning where practical
                  before product application.
                </p>
              </div>
            </div>
            <div class="svc-step">
              <div class="svc-step__num">3</div>
              <div class="svc-step__body">
                <h3>Antimicrobial Application</h3>
                <p>
                  EPA-registered products applied to affected surfaces using targeted application or
                  controlled fogging as appropriate — no bleach-based approach.
                </p>
              </div>
            </div>
            <div class="svc-step">
              <div class="svc-step__num">4</div>
              <div class="svc-step__body">
                <h3>Post-Treatment Documentation</h3>
                <p>
                  Treated areas photographed and documented — providing a baseline record for future
                  reference.
                </p>
              </div>
            </div>
            <div class="svc-step">
              <div class="svc-step__num">5</div>
              <div class="svc-step__body">
                <h3>Humidity Control Plan</h3>
                <p>
                  We recommend a dehumidification and vapor barrier strategy to keep crawl space RH
                  stable at ~50% and reduce the conditions that support regrowth.
                </p>
              </div>
            </div>
          </div>
        </div>
        <div
          class="svc-split__image"
          style="padding-top:0;display:flex;flex-direction:column;gap:1rem;"
        >
          <figure style="margin:0;">
            <img
              src="/images/mold-remediation-crawl-space-raleigh-1.webp"
              alt="Technician spray treating wood surfaces during crawl space mold remediation in Raleigh NC"
              width="780"
              height="260"
              loading="lazy"
              style="width:100%;height:260px;object-fit:cover;border-radius:var(--radius-md);display:block;"
            />
            <figcaption
              style="text-align:center;font-size:0.85rem;color:#555;margin-top:0.45rem;font-weight:600;letter-spacing:0.01em;"
            >
              Spray Treat all Wood Surfaces
            </figcaption>
          </figure>
          <figure style="margin:0;">
            <img
              src="/images/mold-remediation-crawl-space-raleigh-nc.webp"
              alt="Fogging entire crawl space during mold remediation in Raleigh NC"
              width="780"
              height="260"
              loading="lazy"
              style="width:100%;height:260px;object-fit:cover;border-radius:var(--radius-md);display:block;"
            />
            <figcaption
              style="text-align:center;font-size:0.85rem;color:#555;margin-top:0.45rem;font-weight:600;letter-spacing:0.01em;"
            >
              Fog Entire Crawl Space
            </figcaption>
          </figure>
        </div>
      </div>
    </div>
  </section>

  <!-- BOTANICAL TREATMENT -->
  <section class="section">
    <div class="container">
      <div class="svc-split">
        <div>
          <h2>EPA-Registered Mold Treatment Products</h2>
          <span class="answer-first"
            >We use EPA-registered antimicrobial products selected for crawl space applications,
            with application methods designed to minimize disruption.</span
          >
          <p>
            We use EPA-registered products including Benefect Botanical Decon 30 and Concrobium Mold
            Control, both commonly used in professional restoration settings.
          </p>
          <div class="feature-list">
            <div class="feature-item">
              <span class="feature-check"
                ><svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  ><circle cx="12" cy="12" r="10"></circle><path d="m9 12 2 2 4-4"></path></svg
                ></span
              >
              <span
                >Benefect Botanical Decon 30 — botanical, thymol-based, EPA-registered disinfectant
                used in restoration workflows</span
              >
            </div>
            <div class="feature-item">
              <span class="feature-check"
                ><svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  ><circle cx="12" cy="12" r="10"></circle><path d="m9 12 2 2 4-4"></path></svg
                ></span
              >
              <span
                >Concrobium Mold Control — EPA-registered; used to inhibit mold growth and leaves a
                residue barrier when applied per label</span
              >
            </div>
            <div class="feature-item">
              <span class="feature-check"
                ><svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  ><circle cx="12" cy="12" r="10"></circle><path d="m9 12 2 2 4-4"></path></svg
                ></span
              >
              <span>No bleach-based shock approach</span>
            </div>
            <div class="feature-item">
              <span class="feature-check"
                ><svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  ><circle cx="12" cy="12" r="10"></circle><path d="m9 12 2 2 4-4"></path></svg
                ></span
              >
              <span
                >Material-compatible approach for crawl space wood framing when applied correctly</span
              >
            </div>
          </div>
        </div>
        <div class="svc-split__image" style="padding-top:0;">
          <img
            src="/images/mold-benefect-disinfectant-crawl-space.webp"
            alt="Benefect botanical disinfectant used for crawl space mold treatment"
            width="780"
            height="320"
            loading="lazy"
            style="width:100%;height:320px;object-fit:cover;border-radius:var(--radius-md);display:block;"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- SCOPE -->
  <section class="section">
    <div class="container narrow">
      <h2>What We Do — and What We Don't Do</h2>
      <span class="answer-first"
        >We provide crawl space surface treatment and humidity correction. We do not provide mold
        clearance testing or medical advice.</span
      >
      <div class="clarification-box">
        <p><strong>We do not:</strong></p>
        <ul class="clarification-list">
          <li>Perform full structural tear-out remediation</li>
          <li>Treat mold inside living areas</li>
          <li>Clean HVAC duct systems</li>
          <li>Provide mold clearance testing or air quality certification</li>
        </ul>
      </div>
      <p class="section-top-sm">
        If we observe conditions outside our scope — structural concerns or living-area
        contamination — we document what we see and limit our work to crawl space moisture control
        and surface treatment within the crawl space.
      </p>
    </div>
  </section>

  <!-- SURFACE MOLD VS ROT -->
  <section class="section">
    <div class="container narrow">
      <h2>Surface Mold vs. Structural Wood Rot</h2>
      <span class="answer-first"
        >Surface mold treated at early stages leaves wood structurally intact — the goal is to halt
        active growth and eliminate the conditions that allowed it to develop.</span
      >
      <p>
        Surface mold — typically appearing as white, gray, or black discoloration on wood framing —
        is different from wood rot, which involves structural degradation of the wood fiber itself.
        Treatment performed before mold penetrates deep into the wood grain typically does not
        compromise structural integrity.
      </p>
      <p>Signs that structural assessment may be needed:</p>
      <div class="signs-grid signs-grid--2col section-top-sm">
        <div class="sign-card">
          <div class="sign-card__icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--color-primary)"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path
                d="M2 12l10 5 10-5"></path></svg
            >
          </div>
          <p>Soft, spongy, or crumbling wood when pressed</p>
        </div>
        <div class="sign-card">
          <div class="sign-card__icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--color-primary)"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><path
                d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"
              ></path><line x1="12" y1="9" x2="12" y2="13"></line><line
                x1="12"
                y1="17"
                x2="12.01"
                y2="17"></line></svg
            >
          </div>
          <p>Fungal growth with a shelf-like or 3D structure</p>
        </div>
        <div class="sign-card">
          <div class="sign-card__icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--color-primary)"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline
                points="9 22 9 12 15 12 15 22"></polyline></svg
            >
          </div>
          <p>Sagging floors above the crawl space</p>
        </div>
        <div class="sign-card">
          <div class="sign-card__icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--color-primary)"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path></svg
            >
          </div>
          <p>Visible separation or cracking along the wood grain</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PREVENTION -->
  <section class="section">
    <div class="container narrow">
      <h2>Mold Prevention Requires Both Treatment + Humidity Control</h2>
      <span class="answer-first"
        >The most effective long-term approach is treating existing growth and controlling humidity
        so it doesn't return.</span
      >
      <p>
        Crawl Space mold is rarely solved by treatment alone, and humidity control alone doesn't
        remove existing growth. We combine surface treatment with a humidity control plan designed
        to keep crawl space RH stable — typically 45–50% RH after corrective work — reducing the
        conditions that support regrowth.
      </p>
      <p>
        For vented crawl spaces see our <a href="/crawl-space-dehumidifier-raleigh-nc/"
          >professional crawl space dehumidifier installation in Raleigh</a
        >. For sealed systems see our <a href="/encapsulated-crawl-space-dehumidifier-raleigh-nc/"
          >encapsulated crawl space dehumidifier installation</a
        > page.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        <details class="faq-item">
          <summary>What causes mold to grow in crawl spaces in Raleigh, NC?</summary>
          <p>
            Crawl Space mold is caused by sustained high Relative Humidity (RH) — typically above
            60% for extended periods. In Raleigh and Wake County, the primary drivers are ground
            moisture evaporating through unprotected soil, humid exterior air entering through open
            vents, inadequate vapor barrier coverage, and plumbing condensation or leaks. Mold grows
            on wood framing and subfloor materials when moisture conditions are not controlled.
          </p>
        </details>
        <details class="faq-item">
          <summary>Can crawl space mold spread into living areas?</summary>
          <p>
            Yes. The Stack Effect pulls crawl space air upward into the living space through
            subfloor gaps, plumbing penetrations, and HVAC pathways. Mold spores, musty odors, and
            elevated humidity from an uncontrolled crawl space can enter and affect the air quality
            in your home. Correcting crawl space humidity at the source is the most effective way to
            prevent this.
          </p>
        </details>
        <details class="faq-item">
          <summary>Does bleach kill crawl space mold?</summary>
          <p>
            Bleach is not recommended for crawl space mold treatment on wood framing. Bleach does
            not penetrate porous wood surfaces effectively and can leave behind moisture that
            promotes regrowth. We use EPA-registered antimicrobial products — including Benefect
            Botanical Decon 30 and Concrobium Mold Control — which are selected specifically for
            crawl space wood applications and professional restoration workflows.
          </p>
        </details>
        <details class="faq-item">
          <summary>Will mold come back after crawl space treatment?</summary>
          <p>
            Mold will return if the underlying humidity is not corrected. Surface treatment removes
            existing growth, but if crawl space RH continues to exceed 60%, conditions for regrowth
            remain. The most effective long-term approach is combining treatment with a
            dehumidification strategy that maintains crawl space RH at 45–50% year-round.
          </p>
        </details>
        <details class="faq-item">
          <summary>How much does crawl space mold treatment cost in Raleigh, NC?</summary>
          <p>
            Crawl Space mold treatment cost varies based on the size of the affected area,
            accessibility, and whether moisture correction equipment is needed. An in-person
            inspection is the best way to determine accurate scope and pricing for your specific
            crawl space.
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- RELATED READING -->
  <section class="container" style="padding-block:2rem;">
    <h2 style="font-size:1.35rem;margin-bottom:1rem;">Related Reading</h2>
    <ul style="list-style:none;padding:0;display:flex;flex-direction:column;gap:.75rem;">
      <li><a href="/blog/signs-your-home-has-humidity-problem/">5 Signs Your Home Has a Humidity Problem</a></li>
      <li><a href="/blog/why-raleigh-homes-have-humidity-problems/">Why Raleigh Homes Have Humidity Problems</a></li>
      <li><a href="/blog/crawl-space-encapsulation-vs-dehumidifier-raleigh/">Encapsulation vs. Dehumidifier: What Raleigh Homes Need</a></li>
    </ul>
  </section>

