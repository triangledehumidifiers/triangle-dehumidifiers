            height="320"
            loading="lazy"
            style="width:100%;height:320px;object-fit:cover;border-radius:var(--radius-md);display:block;"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 5 -->
  <section class="section">
    <div class="container">
      <h2>Signs Your Encapsulated Crawl Space Has High Humidity</h2>
      <span class="answer-first"
