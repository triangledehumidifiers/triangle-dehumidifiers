const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Do encapsulated crawl spaces need ventilation?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sealed crawl spaces do not use traditional vents. Instead, they rely on a dehumidifier to control humidity and maintain 45–50% RH. Some sealed systems also incorporate a small supply of conditioned air from the HVAC system.',
