                  xmlns="http://www.w3.org/2000/svg"
                  width="28"
                  height="28"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#4f7d2a"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  ><path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"></path><path
                    d="M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
                  ></path></svg
                ></span
              >
              <div>
                <strong>Tight Construction</strong>
                <p>
                  Newer or tighter homes with poor natural air exchange benefit most from controlled
                  ventilation
                </p>
              </div>
            </div>
            <div class="icon-card">
              <span class="icon-card__icon"
                ><svg
