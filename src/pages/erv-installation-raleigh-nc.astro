---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildBusinessSchema, ALL_AREAS_SERVED } from '../schemas/business';

const schema = buildBusinessSchema({
  areaServed: ALL_AREAS_SERVED,
});
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Will an ERV lower humidity?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'An ERV reduces humidity load compared to straight outside-air ventilation, but it is not a dehumidifier. In most Triangle-area homes, dedicated dehumidification is still needed alongside an ERV.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does an ERV replace a dehumidifier?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No. In humid climates like North Carolina, ERVs and dedicated dehumidification often work together. An ERV manages fresh air. A dehumidifier controls RH. Both serve different functions.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do I need an ERV or an HRV?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'In humid climates, ERVs are generally preferred because they transfer some moisture between airstreams, helping temper incoming air. Final choice depends on the home, the HVAC system, and your specific goals.',
      },
    },
    {
      '@type': 'Question',
      name: 'Will an ERV make my house more humid?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'In humid climates, unmanaged ventilation can increase indoor RH. Proper ERV design, sizing, and integration with a dehumidification strategy prevents this.',
      },
    },
    {
      '@type': 'Question',
      name: 'How much does ERV installation cost in Raleigh?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ERV installation cost in Raleigh varies based on duct routing, attic or crawl space access, existing HVAC configuration, and integration complexity. An in-person evaluation is the best way to determine accurate pricing for your specific home.',
      },
    },
    {
      '@type': 'Question',
      name: 'How does an ERV improve indoor air quality in Raleigh, NC?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'An ERV continuously replaces stale indoor air with fresh outdoor air while recovering energy from the exhaust stream. This reduces CO2 buildup, allergens, and household odors while minimizing humidity and energy impact — improving air quality without significantly increasing energy costs.',
      },
    },
    {
      '@type': 'Question',
      name: 'How often do ERV filters need changing?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ERV filters typically need inspection every 3–6 months and replacement annually, depending on local air quality and usage. We design every installation with accessible filter locations to make routine maintenance straightforward.',
      },
    },
  ],
};
---

<BaseLayout
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'ERV Installation', url: '/erv-installation-raleigh-nc' },
  ]}
  title="ERV Installation Raleigh NC | Fresh Air Ventilation"
  description="Professional ERV installation in Raleigh, NC. Balanced fresh air ventilation for Wake County's humid climate. Integrated humidity control."
  canonical="/erv-installation-raleigh-nc"
  heroImage="/images/erv-installation-raleigh-nc.webp"
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- HERO -->
  <section class="svc-hero">
    <div class="container">
      <h1>ERV Installation in Raleigh, NC — Fresh Air Ventilation</h1>
      <span class="svc-hero__direct"
        >Professional ERV installation designed for Wake County's humid climate and modern tight
        homes.</span
      >
      <p class="svc-hero__sub">
        An ERV (Energy Recovery Ventilator) brings fresh outdoor air into your home while
        transferring heat and moisture between incoming and outgoing air streams — improving indoor
        air quality without driving up humidity or energy costs.
      </p>
      <div class="svc-hero__actions">
        <a href="/contact/" class="btn btn-green">Schedule Fresh-Air &amp; Humidity Evaluation</a>
        <a
          href="tel:9198670580"
          class="btn btn-secondary"
          aria-label="Call Triangle Dehumidifiers at (919) 867-0580">Call (919) 867-0580</a
        >
        <a
          href="sms:9198670580"
          class="btn btn-secondary"
          aria-label="Text Triangle Dehumidifiers at (919) 867-0580">Text (919) 867-0580</a
        >
      </div>
      <div style="display:flex; gap:1.5rem; margin-top:1.25rem; flex-wrap:wrap;">
        <span style="font-size:0.85rem; color:#4a5a6a;">✓ Balanced airflow design</span>
        <span style="font-size:0.85rem; color:#4a5a6a;">✓ Humidity-aware ventilation strategy</span>
        <span style="font-size:0.85rem; color:#4a5a6a;"
          >✓ Integrated with dehumidification when needed</span
        >
      </div>
    </div>
  </section>

  <!-- WHY ERV MATTERS -->
  <section class="section">
    <div class="container" style="max-width:780px;">
      <h2>Why ERV Installation Matters in This Area</h2>
      <span class="answer-first"
        >In Wake County's humid climate, outdoor air can raise indoor Relative Humidity (RH) if
        introduced without control.</span
      >
      <p>
        An ERV transfers heat and some moisture between air streams, helping temper incoming air
        before it enters the home. This makes balanced fresh-air ventilation in the Triangle region
        fundamentally different from simply opening a window or adding an intake fan.
      </p>
      <p>
        ERVs improve ventilation and energy performance, but because humid outdoor air can still
        raise indoor moisture, they are often paired with <a
          href="/whole-house-dehumidifier-raleigh/">whole-home dehumidification systems</a
        > for balanced comfort and stable RH control.
      </p>
    </div>
  </section>

  <!-- WHAT AN ERV DOES -->
  <section class="section">
    <div class="container">
      <div class="svc-split">
        <div>
          <h2>What an ERV Does</h2>
          <span class="answer-first"
            >An ERV provides balanced fresh-air ventilation while transferring heat and moisture
            between incoming and outgoing air — improving indoor air quality without spiking
            humidity.</span
          >
          <p>
            In tight homes, ventilation matters. An ERV helps control stale air, odors, and indoor
            pollutants without the "open a window" approach that can drive humidity to damaging
            levels during North Carolina summers.
          </p>
          <p>
            ERVs provide balanced ventilation — exhausting stale indoor air while bringing in
            filtered outdoor air at the same rate to maintain neutral pressure inside the home.
          </p>
          <div class="feature-list">
            <div class="feature-item">
              <span class="feature-check"
