          </div>
        </div>
        <div class="svc-split__image" style="padding-top:0;">
          <img
            src="/images/erv-installation-raleigh-nc.webp"
            alt="ERV installation in Raleigh NC"
            width="780"
            height="320"
            fetchpriority="high"
            style="width:100%;height:auto;max-height:420px;object-fit:cover;object-position:center top;border-radius:var(--radius-md);display:block;"
          />
