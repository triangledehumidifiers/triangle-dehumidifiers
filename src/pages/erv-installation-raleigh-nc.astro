  <!-- WHEN IT MAKES SENSE -->
  <section class="section">
    <div class="container">
      <div class="svc-split">
        <div>
          <h2>When an ERV Makes Sense</h2>
          <span class="answer-first"
            >ERVs are most useful when the home is tight or when indoor air quality issues persist
            despite other measures.</span
          >
          <div class="icon-cards">
            <div class="icon-card">
              <span class="icon-card__icon"
