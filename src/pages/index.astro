  </section>

  <script>
    (function () {
      const track = document.getElementById('reviews-track');
      const viewport = document.getElementById('reviews-viewport');
      const prevBtn = document.getElementById('reviews-prev');
      const nextBtn = document.getElementById('reviews-next');
      if (!track || !viewport) return;

      const origCards = Array.from(track.children);
      const total = origCards.length;
      let idx = 0;
      let timer;
      let isTransitioning = false;

      function visibleCount() {
        const w = window.innerWidth;
        if (w <= 640) return 1;
        if (w <= 900) return 2;
        return 3;
      }

      /* Clone enough cards at the end so the wrap is seamless */
      function buildClones() {
        track.querySelectorAll('.review-card--clone').forEach(function (c) { c.remove(); });
        var vc = visibleCount();
        for (var i = 0; i < vc; i++) {
          var clone = origCards[i % total].cloneNode(true);
          clone.classList.add('review-card--clone');
          clone.setAttribute('aria-hidden', 'true');
          track.appendChild(clone);
        }
      }

      function getStep() {
        var gap = parseFloat(getComputedStyle(track).gap) || 0;
        var cardW = origCards[0].offsetWidth;
        return cardW + gap;
      }

      function slide(animate) {
        if (animate === false) {
          track.style.transition = 'none';
        } else {
          track.style.transition = 'transform 1.4s cubic-bezier(0.25, 0.1, 0.25, 1)';
        }
        track.style.transform = 'translateX(-' + idx * getStep() + 'px)';
        if (animate === false) {
          /* Force reflow so the instant jump is applied */
          track.offsetHeight;
        }
      }

      /* When the transition ends at the clone zone, silently jump back */
      track.addEventListener('transitionend', function () {
        isTransitioning = false;
        if (idx >= total) {
          idx = idx - total;
          slide(false);
        }
        if (idx < 0) {
          idx = idx + total;
          slide(false);
        }
      });

      function goNext() {
        if (isTransitioning) return;
        isTransitioning = true;
        idx++;
        slide(true);
      }

      function goPrev() {
        if (isTransitioning) return;
        if (idx === 0) {
          /* Jump to the end instantly, then animate one step back */
          idx = total;
          slide(false);
          requestAnimationFrame(function () {
            isTransitioning = true;
            idx--;
            slide(true);
          });
        } else {
          isTransitioning = true;
          idx--;
          slide(true);
        }
      }

      function resetTimer() {
        clearInterval(timer);
        timer = setInterval(goNext, 6000);
      }

      prevBtn.addEventListener('click', function () { goPrev(); resetTimer(); });
      nextBtn.addEventListener('click', function () { goNext(); resetTimer(); });

      track.closest('.reviews-carousel__stage').addEventListener('mouseenter', function () {
        clearInterval(timer);
      });
      track.closest('.reviews-carousel__stage').addEventListener('mouseleave', resetTimer);

      buildClones();
      slide(false);
      resetTimer();

      var rTimer;
      window.addEventListener('resize', function () {
        clearTimeout(rTimer);
        rTimer = setTimeout(function () {
          buildClones();
          if (idx >= total) idx = 0;
          slide(false);
        }, 200);
      });

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        clearInterval(timer);
      }
    })();
  </script>

