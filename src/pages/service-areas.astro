---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Service Areas', url: '/service-areas' }]}
  title="Service Areas | Triangle Dehumidifiers | Wake County NC"
  description="Triangle Dehumidifiers serves Raleigh, Cary, Apex, Holly Springs & Wake County NC with crawl space dehumidifier, mold treatment, and ERV installation."
  canonical="/service-areas"
>
  <!-- HERO -->
  <section class="svc-hero">
    <div class="container">
      <h1>
        Dehumidifier, Crawl Space Mold &amp; Ventilation<br />Services in Wake County &amp; the
        Triangle
      </h1>
      <span class="svc-hero__direct"
        >Professional humidity control, crawl space mold treatment, and fresh-air ventilation for
        homeowners throughout Wake County and the greater Triangle region of NC.</span
      >
      <p class="svc-hero__sub">
        Serving Raleigh, Cary, Apex, Holly Springs, Fuquay-Varina, Morrisville, Garner, Wake Forest,
        Knightdale, Durham, Chapel Hill, and surrounding Triangle communities.
      </p>
      <div class="svc-hero__actions">
        <a href="/contact" class="btn btn-green">Request Inspection</a>
        <a href="tel:9198670580" class="btn btn-secondary">Call (919) 867-0580</a>
      </div>
    </div>
  </section>

  <!-- MAP -->
  <section class="section">
    <div class="container">
      <div
        style="background:#f7f9fc; border:1px solid #d0d9e4; border-radius:8px; padding:1.5rem; margin:0 auto 2rem; max-width:900px; text-align:center;"
      >
        <p
          style="font-size:0.8rem; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:#122f5b; margin-bottom:1rem;"
        >
          Primary &amp; Extended Service Area
        </p>
        <div style="border-radius:var(--radius-md);overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,0.10);">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d541213.1673605165!2d-78.82169149999999!3d35.84062555!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2126c9cf824e241d%3A0x883595d6b0c9b047!2sTriangle%20Dehumidifiers%2C%20LLC!5e1!3m2!1sen!2sus!4v1773372401756!5m2!1sen!2sus"
            width="100%"
            height="450"
            style="border:0;display:block;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Triangle Dehumidifiers service area map — Raleigh, Cary, Apex, Holly Springs, Wake County NC"
          ></iframe>
        </div>
      </div>
      <p style="max-width:900px; margin:0 auto; font-size:1rem; color:#4a5a6a; line-height:1.8;">
        We provide crawl space dehumidifier installation, whole-home dehumidifiers, ERV ventilation
        systems, and crawl space mold treatment throughout Raleigh, Wake County, and the greater
        Triangle region. Most projects are completed in Wake County with extended service available
        in Durham, Chapel Hill, Pittsboro, Clayton, and surrounding communities.
      </p>
    </div>
  </section>

  <!-- PRIMARY SERVICE AREA -->
  <section class="section">
    <div class="container">
      <div class="svc-split">
        <div>
          <h2>Raleigh &amp; Wake County</h2>
          <span class="answer-first"
            >We serve all of Wake County with priority scheduling and local service response.</span
          >
          <ul class="svc-list" style="margin-top:1.25rem;">
            <li><a href="/crawl-space-dehumidifier-raleigh-nc">Raleigh</a></li>
            <li><a href="/crawl-space-dehumidifier-cary-nc">Cary</a></li>
            <li><a href="/crawl-space-dehumidifier-apex-nc">Apex</a></li>
            <li>Morrisville</li><!-- TODO: create /crawl-space-dehumidifier-morrisville-nc and link -->
            <li><a href="/crawl-space-dehumidifier-holly-springs-nc">Holly Springs</a></li>
            <li><a href="/crawl-space-dehumidifier-fuquay-varina-nc">Fuquay-Varina</a></li>
            <li>Garner</li><!-- TODO: create /crawl-space-dehumidifier-garner-nc and link -->
            <li>Knightdale</li><!-- TODO: create /crawl-space-dehumidifier-knightdale-nc and link -->
            <li>Wake Forest</li><!-- TODO: create /crawl-space-dehumidifier-wake-forest-nc and link -->
          </ul>
        </div>
        <div>
          <h2>Triangle Region &amp; Surrounding Communities</h2>
          <span class="answer-first"
            >We also provide service throughout the greater Triangle area, including longer-distance
            appointments.</span
          >
          <ul class="svc-list" style="margin-top:1.25rem;">
            <li>Durham</li><!-- TODO: create /crawl-space-dehumidifier-durham-nc and link -->
            <li>Chapel Hill</li><!-- TODO: create /crawl-space-dehumidifier-chapel-hill-nc and link -->
            <li>Pittsboro</li><!-- TODO: create /crawl-space-dehumidifier-pittsboro-nc and link -->
            <li>Clayton</li><!-- TODO: create /crawl-space-dehumidifier-clayton-nc and link -->
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES WE PROVIDE -->
  <section class="section">
    <div class="container" style="max-width:780px;">
      <h2>Services We Provide in These Areas</h2>
      <span class="answer-first"
        >We offer a full range of humidity control and ventilation services for homeowners
        throughout the Triangle region.</span
      >
      <div class="feature-list" style="margin-top:1.25rem;">
        <div class="feature-item">
          <span class="feature-check"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg></span>
          <span
            ><a href="/crawl-space-dehumidifier-installation-raleigh"
              >Crawl Space dehumidifier installation</a
            > — vented crawl space systems</span
          >
        </div>
        <div class="feature-item">
          <span class="feature-check"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg></span>
          <span
            ><a href="/encapsulated-crawl-space-dehumidifier-raleigh-nc"
              >Encapsulated crawl space dehumidifier systems</a
            > — sealed environment humidity control</span
          >
        </div>
        <div class="feature-item">
          <span class="feature-check"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg></span>
          <span
            ><a href="/whole-house-dehumidifier-raleigh">Whole-home dehumidifiers</a> — HVAC ducted and
            dedicated systems</span
          >
        </div>
        <div class="feature-item">
          <span class="feature-check"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg></span>
          <span
            ><a href="/erv-installation-raleigh-nc">ERV / fresh-air ventilation systems</a> — energy recovery
            ventilation installation</span
          >
        </div>
        <div class="feature-item">
          <span class="feature-check"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg></span>
          <span
            ><a href="/crawl-space-mold-treatment-raleigh">Crawl Space mold treatment</a> — botanical antimicrobial
            surface treatment</span
          >
        </div>
      </div>
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section class="svc-cta">
    <div class="container svc-cta__inner">
      <h2>Schedule a Crawl Space or Home Evaluation</h2>
      <p>Serving Raleigh, Wake County, and the greater Triangle region of NC.</p>
      <a href="/contact" class="btn btn-green">Request Inspection</a>
      <span class="svc-cta__trust">Fully insured. Wake County–based.</span>
    </div>
  </section>
</BaseLayout>
