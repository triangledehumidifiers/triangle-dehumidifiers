---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildBusinessSchema, ALL_AREAS_SERVED } from '../schemas/business';

const schema = buildBusinessSchema({
  areaServed: ALL_AREAS_SERVED,
});
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is the ideal indoor humidity level for a home in Raleigh, NC?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "For Raleigh-area homes, we target 45–50% Relative Humidity (RH). Industry guidance cites 40–60% RH as acceptable, but tighter control at 45–50% provides better mold prevention and comfort in North Carolina's humid climate.",
      },
    },
    {
      '@type': 'Question',
      name: 'Can a whole-house dehumidifier run without the AC?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Whole-house dehumidifiers operate independently of cooling, maintaining stable RH even when the AC is off during mild weather.',
      },
    },
    {
      '@type': 'Question',
      name: 'HVAC integrated vs. independent — which is better?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Both work well. HVAC integrated systems use existing ductwork for distribution. Independent systems have their own dedicated ductwork and airflow, making them suitable when HVAC duct access is limited.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do whole-house dehumidifiers need a drain?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Continuous drainage is standard — gravity drain or condensate pump. No manual emptying required.',
      },
    },
    {
      '@type': 'Question',
      name: 'How long do whole-house dehumidifiers last?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Properly installed and maintained whole-house dehumidifiers typically last 7–10 years.',
      },
    },
    {
      '@type': 'Question',
      name: 'How much does a whole-house dehumidifier cost in Raleigh?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Most whole-house dehumidifier installations in the Raleigh area run $3,000–$5,000 for a standard HVAC integration, and $4,000–$6,000 for more complex or older systems. Operating cost is typically $8–$15 per month.',
      },
    },
    {
      '@type': 'Question',
      name: 'Will a whole-house dehumidifier increase my electric bill?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A whole-house dehumidifier typically adds $8–$15 per month to your electric bill. Many homeowners offset some of that cost by running their AC less aggressively once indoor humidity is independently controlled.',
      },
    },
  ],
};
---

<BaseLayout
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Whole-Home Dehumidifier', url: '/whole-house-dehumidifier-raleigh' },
  ]}
  title="Whole-House Dehumidifier Raleigh NC | Triangle Dehumidifiers"
  description="Whole-house dehumidifier installation in Raleigh NC. HVAC-integrated and standalone systems for 45-50% humidity year-round. Free evaluation."
  canonical="/whole-house-dehumidifier-raleigh"
  heroImage="/images/whole-house-dehumidifier-installation-raleigh-nc.webp"
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- HERO -->
  <section class="svc-hero">
    <div class="container">
      <h1>Whole-House Dehumidifier Installation in Raleigh, NC</h1>
      <span class="svc-hero__direct"
        >If your HVAC system cannot keep indoor humidity below 50%, a whole-house dehumidifier
        provides dedicated moisture control year-round.</span
      >
      <p class="svc-hero__sub">
        Air conditioners are designed to cool, not continuously control humidity. We install
        HVAC-integrated and dedicated whole-house dehumidifier systems that maintain 45–50% Relative
        Humidity (RH) across Raleigh and the Triangle region — even when the AC is not running.
      </p>
      <div class="svc-hero__actions">
        <a href="/contact/" class="btn btn-green">Request Home Evaluation</a>
        <a
          href="tel:9198670580"
          class="btn btn-secondary"
          aria-label="Call Triangle Dehumidifiers at (919) 867-0580">Call (919) 867-0580</a
        >
        <a
          href="sms:9198670580"
          class="btn btn-secondary"
          aria-label="Text Triangle Dehumidifiers at (919) 867-0580">Text (919) 867-0580</a
        >
      </div>
      <div style="display:flex; gap:1.5rem; margin-top:1.25rem; flex-wrap:wrap;">
        <span style="font-size:0.85rem; color:#4a5a6a;">✓ Inspection-based sizing</span>
        <span style="font-size:0.85rem; color:#4a5a6a;">✓ Continuous drainage — no buckets</span>
        <span style="font-size:0.85rem; color:#4a5a6a;">✓ Verified RH performance</span>
      </div>
    </div>
  </section>

  <!-- WHY HVAC IS NOT ENOUGH — IMAGE 1: installation -->
  <section class="section">
    <div class="container">
      <div class="svc-split">
        <div>
          <h2>Why HVAC Alone Is Not Enough</h2>
          <span class="answer-first"
            >Air conditioning removes moisture only while actively cooling.</span
          >
          <p>
            During mild spring and fall weather, your AC short-cycles or doesn't run at all —
            leaving indoor humidity uncontrolled. High-efficiency systems cool so quickly they don't
            run long enough to remove meaningful moisture from the air.
          </p>
          <p>
            Indoor humidity above 60% increases mold growth risk. Indoor RH routinely stays at
            55–65% during shoulder seasons — well above the threshold where mold becomes active and
            dust mites thrive.
          </p>
          <div class="icon-cards">
            <div class="icon-card">
              <span class="icon-card__icon"
                ><svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="28"
                  height="28"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#1a6fa8"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  ><line x1="2" x2="22" y1="12" y2="12"></line><line x1="12" x2="12" y1="2" y2="22"
                  ></line><path d="m20 16-4-4 4-4"></path><path d="m4 8 4 4-4 4"></path><path
                    d="m16 4-4 4-4-4"></path><path d="m8 20 4-4 4 4"></path></svg
                ></span
              >
              <div>
                <strong>Short Cycling</strong>
                <p>AC turns off before removing enough moisture — especially in spring and fall</p>
              </div>
            </div>
            <div class="icon-card">
              <span class="icon-card__icon"
