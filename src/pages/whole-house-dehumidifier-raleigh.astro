            height="520"
            fetchpriority="high"
            style="width:100%;height:auto;object-fit:cover;border-radius:var(--radius-md);display:block;"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT IT DOES — IMAGE 2: whole-house -->
